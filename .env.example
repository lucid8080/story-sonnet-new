# PostgreSQL (Neon, RDS, local, etc.)
# Copy to `.env` (gitignored). Next.js also reads `.env.local` if you use it; Prisma CLI loads `.env` automatically.
DATABASE_URL="postgresql://neondb_owner:npg_S0Ad9VDmHtyc@ep-shy-rain-anva7zwy-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth / Auth.js v5 — generate secret with: openssl rand -base64 32
# Prefer AUTH_* in new deployments; NEXTAUTH_* is still supported.
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="u9uf984j9r8fj38049jf39084jf38904fj283904urjf8904f4uehf9023j23409jthf90234fjiuk"
NEXTAUTH_URL="http://localhost:3000"

# Optional: same value as GOOGLE_CLIENT_ID so the login page can show the Google button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Public site URL (Stripe redirects, emails)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: comma-separated hostnames when you open the dev server from another device (LAN).
# Example: NEXT_DEV_ALLOWED_ORIGINS=192.168.0.40
# NEXT_DEV_ALLOWED_ORIGINS=

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Monthly recurring price (e.g. $10/mo)
STRIPE_PRICE_ID=""
# Yearly recurring price — create in Stripe as $96/year (20% off vs 12× monthly)
STRIPE_PRICE_ID_ANNUAL=""

# Cloudflare R2 (S3-compatible) — primary names for this project
R2_ACCOUNT_ID="50bc8e9aaa1448fe6e9e0b46ebcd64af"
R2_ACCESS_KEY_ID="c854d02df13781343a632e95279f0b67"
R2_SECRET_ACCESS_KEY="9a012124c0e80f8c590ccd6422f2d516cef67a84026ec93490cd3c38afde0c02"
R2_BUCKET=story-sonnet-assets
# Private bucket for paywalled MP3s (recommended). If unset, presigned playback uses R2_BUCKET.
# R2_PRIVATE_BUCKET=story-sonnet-audio-private
# Public URL for objects (custom domain or *.r2.dev bucket URL), no trailing slash
R2_PUBLIC_BASE_URL="http://localhost:3000"

# Optional fallbacks for other S3 providers (used if R2_* not set)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_REGION="auto"
# S3_BUCKET=""
# S3_ENDPOINT=""
# S3_PUBLIC_BASE_URL=""

# Static story assets (covers/audio URLs in bundled data fallback)
NEXT_PUBLIC_ASSETS_BASE_URL="https://assets.your-domain.com"

# Optional: Mistral / TTS (if you use scripts that reference these)
# MISTRAL_API_KEY=
# MISTRAL_TTS_MODEL=

# --- Story Studio (admin /admin/story-studio) — server-only; never expose to client
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
# Optional: ElevenLabs model id (defaults to eleven_multilingual_v2 in code)
# ELEVENLABS_MODEL_ID=
SUNO_API_KEY=""
# Required for Suno adapter once you wire the real base URL
SUNO_API_URL=""
# Cover / poster generation via OpenRouter images endpoint
STORY_STUDIO_IMAGE_API_KEY=""
STORY_STUDIO_IMAGE_MODEL="google/gemini-2.5-flash-image"
# OpenRouter chat completions endpoint (image models via `modalities: ["image", "text"]`)
STORY_STUDIO_IMAGE_API_URL="https://openrouter.ai/api/v1/chat/completions"
# Optional: path to ffmpeg binary for theme intro trim (otherwise theme_intro step may fail on serverless)
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
# Optional: future Suno webhooks
# STORY_STUDIO_WEBHOOK_SECRET=
