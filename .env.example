# Story Sonnet local secrets
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_TTS_MODEL=voxtral-mini-tts-2603
# Primary path: set a reusable saved voice id when ready
# MISTRAL_TTS_VOICE_ID=your_saved_voice_id
# Fallback path: or point to a short (<60s) reference clip
# MISTRAL_TTS_REF_AUDIO=/absolute/path/to/reference-sample.mp3

# Base URL for audio and cover art hosted on Cloudflare R2
# Example: https://assets.your-domain.com   (no trailing slash)
VITE_ASSETS_BASE_URL=https://assets.your-domain.com
