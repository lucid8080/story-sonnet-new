generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /** Non-pooled URL for Prisma Migrate (Neon: host without `-pooler`). Avoids P1002 advisory lock timeouts. */
  directUrl = env("DIRECT_DATABASE_URL")
}

enum AccountStatus {
  active
  suspended
  banned
  pending
  deleted
}

enum RiskLevel {
  none
  low
  medium
  high
}

enum CreditLedgerType {
  grant
  spend
  refund
  promo
  manual_adjustment
}

enum NoteVisibility {
  internal
  support
}

enum AdminInboxEventType {
  user_signup
  subscription_active
}

enum CampaignType {
  notification_bar
  trial_offer
  promo_code
}

enum CampaignStatus {
  draft
  scheduled
  active
  paused
  expired
}

enum CampaignPlacementKey {
  global_top_bar
  homepage_hero
  pricing_banner
  checkout_callout
  account_dashboard_card
  library_banner
  story_detail_banner
  modal_trigger
}

enum CampaignAudience {
  all
  logged_out
  logged_in
  subscribers
  free_users
  trial_users
  new_users
}

enum NotificationDismissPolicy {
  session
  hours_24
  days_7
  until_campaign_end
}

enum DiscountType {
  percent
  fixed_cents
  trial_extension_days
  free_first_payment
}

enum PromoDurationMode {
  once
  recurring_cycles
  forever
}

enum PromoStackingRule {
  none
  with_trial
  with_announcement_only
}

enum AnalyticsEventType {
  impression
  cta_click
  dismiss
  trial_claim
  promo_validate_ok
  promo_validate_fail
  promo_redeem
  conversion_proxy
}

enum TrialOfferKind {
  fixed_duration
  weekend_trial
  first_month_free
  premium_unlock
}

enum ContentSpotlightType {
  holiday
  awareness_month
  seasonal
  editorial
}

enum ContentSpotlightStatus {
  draft
  scheduled
  active
  paused
  expired
}

enum ContentSpotlightRecurrence {
  one_time
  recurring_yearly
}

enum ContentSpotlightBadgeCorner {
  bottom_right
  bottom_left
  top_right
  top_left
}

// NextAuth models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  storySeriesLikes    StorySeriesLike[]
  userSavedStories    UserSavedStory[]
  storySeriesComments StorySeriesComment[]
  storySeriesRatings  StorySeriesRating[]
  storyStudioDrafts   StoryStudioDraft[]
  customerCreditLedger   CustomerCreditLedger[]
  customerAdminNotes     CustomerAdminNote[]
  customerAuditLogs      CustomerAuditLog[]
  customerPurchases      CustomerPurchase[]
  creditLedgerCreatedBy  CustomerCreditLedger[] @relation("CreditLedgerCreatedBy")
  adminNotesAuthored     CustomerAdminNote[]    @relation("AdminNoteAuthor")
  auditLogsAsActor       CustomerAuditLog[]     @relation("AuditLogActor")
  inboxEventsAsSubject   AdminInboxEvent[]      @relation("InboxEventSubject")
  adminNotificationSeen  AdminNotificationSeen?
  campaignsCreated       Campaign[]             @relation("CampaignCreatedBy")
  campaignAnalyticsEvents CampaignAnalyticsEvent[]
  promoRedemptions       PromoCodeRedemption[]
  trialClaims              TrialClaim[]
  campaignStatusAudits     CampaignStatusHistory[] @relation("CampaignStatusActor")
  badgeAssetsUploaded      BadgeAsset[]             @relation("BadgeAssetUploadedBy")
  blogPostsAuthored        BlogPost[]               @relation("BlogPostAuthor")
}

// --- Blog -------------------------------------------------------------------

enum BlogPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum BlogGenerationSource {
  MANUAL
  AI_SCRATCH
  AI_KEYWORDS
  AI_REWRITE
}

enum BlogKeywordPriority {
  LOW
  MEDIUM
  HIGH
}

enum BlogKeywordStatus {
  UNUSED
  TOPIC_CREATED
  DRAFT_CREATED
  PUBLISHED
  SKIPPED
}

enum BlogKeywordSourceType {
  MANUAL
  IMPORTED
  AI_SUGGESTED
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  accentColor String?  @map("accent_color")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  posts    BlogPost[]
  keywords BlogKeyword[]

  @@index([slug])
  @@index([createdAt])
  @@map("blog_categories")
}

model BlogTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts BlogPostTag[]

  @@index([slug])
  @@index([createdAt])
  @@map("blog_tags")
}

model BlogPostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("blog_post_tags")
}

model BlogKeywordGroup {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  keywords BlogKeyword[]

  @@index([slug])
  @@map("blog_keyword_groups")
}

model BlogPost {
  id                      String               @id @default(cuid())
  title                   String
  slug                    String               @unique
  excerpt                 String?
  contentHtml             String               @map("content_html") @db.Text
  status                  BlogPostStatus       @default(DRAFT)
  featuredImageUrl        String?              @map("featured_image_url")
  featuredImageStorageKey String?              @map("featured_image_storage_key")
  seoTitle                String?              @map("seo_title")
  seoDescription          String?              @map("seo_description") @db.Text
  canonicalUrl            String?              @map("canonical_url")
  authorName              String?              @map("author_name")
  authorId                String?              @map("author_id")
  publishedAt             DateTime?            @map("published_at")
  scheduledAt             DateTime?            @map("scheduled_at")
  isFeatured              Boolean              @default(false) @map("is_featured")
  allowComments           Boolean              @default(false) @map("allow_comments")
  readingTimeMinutes      Int?                 @map("reading_time_minutes")
  viewCount               Int                  @default(0) @map("view_count")
  metaKeywords            String?              @map("meta_keywords") @db.Text
  aiPrompt                String?              @map("ai_prompt") @db.Text
  aiKeywords              Json?                @map("ai_keywords")
  generationSource        BlogGenerationSource @default(MANUAL) @map("generation_source")
  categoryId              String?              @map("category_id")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  category      BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author        User?         @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  tags          BlogPostTag[]
  linkedKeyword BlogKeyword? @relation("BlogPostKeywordLink")

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([scheduledAt])
  @@index([categoryId])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, publishedAt])
  @@index([status, scheduledAt])
  @@map("blog_posts")
}

model BlogKeyword {
  id                  String               @id @default(cuid())
  keyword             String
  normalizedKeyword   String               @unique @map("normalized_keyword")
  searchIntent        String?              @map("search_intent")
  notes               String?              @db.Text
  priority            BlogKeywordPriority  @default(MEDIUM)
  status              BlogKeywordStatus    @default(UNUSED)
  sourceType          BlogKeywordSourceType @default(MANUAL) @map("source_type")
  categoryId          String?              @map("category_id")
  groupId             String?              @map("group_id")
  targetAudience      String?              @map("target_audience")
  relatedQuestions    Json?                @map("related_questions")
  tagsJson            Json?                @map("tags_json")
  assignedTopicTitle  String?              @map("assigned_topic_title")
  assignedBlogPostId  String?              @unique @map("assigned_blog_post_id")
  lastGeneratedAt     DateTime?            @map("last_generated_at")
  completedAt         DateTime?            @map("completed_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  category     BlogCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  group        BlogKeywordGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  assignedPost BlogPost?          @relation("BlogPostKeywordLink", fields: [assignedBlogPostId], references: [id], onDelete: SetNull)

  @@index([keyword])
  @@index([normalizedKeyword])
  @@index([status])
  @@index([priority])
  @@index([categoryId])
  @@index([createdAt])
  @@map("blog_keywords")
}

/// Singleton (id = global): blog admin UI settings (e.g. custom feature-image style presets).
model BlogAdminSettings {
  id                                 String   @id @default("global")
  featureImageStyleCustomPresetsJson Json     @default("[]") @map("feature_image_style_custom_presets_json")
  updatedAt                          DateTime @updatedAt @map("updated_at")

  @@map("blog_admin_settings")
}

model AdminInboxEvent {
  id        String             @id @default(cuid())
  type      AdminInboxEventType
  userId    String             @map("user_id")
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now()) @map("created_at")

  user User @relation("InboxEventSubject", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@map("admin_inbox_events")
}

model AdminNotificationSeen {
  adminUserId String   @id @map("admin_user_id")
  lastSeenAt  DateTime @map("last_seen_at")

  admin User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_notification_seen")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  fullName           String?  @map("full_name")
  avatarUrl          String?  @map("avatar_url")
  role               String   @default("user")
  subscriptionStatus String   @default("free") @map("subscription_status")
  stripeCustomerId   String?  @map("stripe_customer_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  /// Platform account state (distinct from Stripe subscriptionStatus)
  accountStatus AccountStatus @default(active) @map("account_status")
  /// Display tier: free, plus, family, etc.
  subscriptionPlan String? @map("subscription_plan")
  creditBalance    Int     @default(0) @map("credit_balance")
  lastActiveAt     DateTime? @map("last_active_at")
  loginCount       Int       @default(0) @map("login_count")
  lifetimeSpendCents Int     @default(0) @map("lifetime_spend_cents")
  refundCount      Int       @default(0) @map("refund_count")
  /// Denormalized: likes + saves + comments + ratings + studio drafts (refreshed on demand / detail view)
  totalEngagementCount Int   @default(0) @map("total_engagement_count")
  isFlagged        Boolean   @default(false) @map("is_flagged")
  isVip            Boolean   @default(false) @map("is_vip")
  riskLevel        RiskLevel @default(none) @map("risk_level")
  internalTags     Json      @default("[]") @map("internal_tags")
  marketingOptIn   Boolean   @default(false) @map("marketing_opt_in")
  isGuardianManaged Boolean  @default(false) @map("is_guardian_managed")
  isMinorAccount   Boolean   @default(false) @map("is_minor_account")
  consentStatus    String?   @map("consent_status")
  communicationRestricted Boolean @default(false) @map("communication_restricted")
  complianceNotes  String?   @map("compliance_notes")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountStatus])
  @@index([subscriptionStatus])
  @@index([lastActiveAt])
  @@index([createdAt])
  @@map("profiles")
}

model CustomerCreditLedger {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  type             CreditLedgerType
  amount           Int
  balanceAfter     Int              @map("balance_after")
  reason           String           @default("")
  source           String           @default("")
  createdByAdminId String?          @map("created_by_admin_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByAdmin User? @relation("CreditLedgerCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("customer_credit_ledger")
}

model CustomerAdminNote {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  authorAdminId  String         @map("author_admin_id")
  body           String
  visibility     NoteVisibility @default(internal)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorAdmin User @relation("AdminNoteAuthor", fields: [authorAdminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("customer_admin_notes")
}

model CustomerAuditLog {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  actorAdminId String   @map("actor_admin_id")
  actionType   String   @map("action_type")
  reason       String   @default("")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actorAdmin User @relation("AuditLogActor", fields: [actorAdminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actorAdminId])
  @@map("customer_audit_logs")
}

model CustomerPurchase {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  amountCents  Int      @map("amount_cents")
  currency     String   @default("usd")
  status       String   @default("paid")
  productType  String   @default("subscription") @map("product_type")
  provider     String   @default("stripe")
  providerRef  String?  @map("provider_ref")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("customer_purchases")
}

model Story {
  id            BigInt   @id @default(autoincrement())
  slug          String   @unique
  seriesTitle   String   @map("series_title")
  title         String
  subtitle      String?
  ageGroup      String?  @map("age_group")
  ageRange      String?  @map("age_range")
  durationLabel String?  @map("duration_label")
  durationMinutes Int?   @map("duration_minutes")
  durationBucket String? @map("duration_bucket")
  summary       String?
  fullDescription String? @map("full_description")
  coverUrl      String?  @map("cover_url")
  accent        String?
  genre         String?
  mood          String?
  isSeries      Boolean  @default(false) @map("is_series")
  seriesTagline String?  @map("series_tagline")
  universe      String?
  readingLevel  String?  @map("reading_level")
  topics        Json?
  characterTags Json?    @map("character_tags")
  cardTitleOverride String? @map("card_title_override")
  cardDescriptionOverride String? @map("card_description_override")
  badgeLabelOverride String? @map("badge_label_override")
  popularityScore Int      @default(10) @map("popularity_score")
  sortPriority  Int      @default(0) @map("sort_priority")
  publishedAt   DateTime? @map("published_at")
  isFeatured    Boolean  @default(false) @map("is_featured")
  isPublished   Boolean  @default(false) @map("is_published")
  isPremium     Boolean  @default(false) @map("is_premium")
  metaTitle     String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  episodes Episode[]
  studioDrafts StoryStudioDraft[]
  contentSpotlightStories ContentSpotlightStory[]

  @@map("stories")
}

model BadgeAsset {
  id            String   @id @default(cuid())
  name          String
  publicUrl     String   @map("public_url")
  storagePath   String   @map("storage_path")
  mimeType      String   @default("image/png") @map("mime_type")
  width         Int?
  height        Int?
  fileSizeBytes Int?     @map("file_size_bytes")
  altText       String   @default("") @map("alt_text")
  uploadedByUserId String? @map("uploaded_by_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  uploadedBy User? @relation("BadgeAssetUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  spotlights ContentSpotlight[]

  @@index([createdAt])
  @@map("badge_assets")
}

model ContentSpotlight {
  id                    String                    @id @default(cuid())
  internalName          String                    @map("internal_name")
  title                 String
  slug                  String                    @unique
  type                  ContentSpotlightType
  shortBlurb            String                    @map("short_blurb")
  longDescription       String?                   @map("long_description")
  popupTitle            String                    @map("popup_title")
  popupBody             String                    @map("popup_body")
  infoBarText           String                    @map("info_bar_text")
  ctaLabel              String?                   @map("cta_label")
  ctaUrl                String?                   @map("cta_url")
  startAt               DateTime                  @map("starts_at")
  endAt                 DateTime                  @map("ends_at")
  timezone              String                    @default("UTC")
  recurrence            ContentSpotlightRecurrence @default(one_time)
  status                ContentSpotlightStatus    @default(draft)
  publishedAt           DateTime?                 @map("published_at")
  showBadge             Boolean                   @default(true) @map("show_badge")
  badgeCorner           ContentSpotlightBadgeCorner @default(bottom_right) @map("badge_corner")
  showPopup             Boolean                   @default(true) @map("show_popup")
  showInfoBar           Boolean                   @default(true) @map("show_info_bar")
  featureOnHomepage     Boolean                   @default(false) @map("feature_on_homepage")
  featureOnLibraryPage  Boolean                   @default(false) @map("feature_on_library_page")
  priority              Int                       @default(0)
  themeToken            String?                   @map("theme_token")
  badgeAssetId          String?                   @map("badge_asset_id")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  badgeAsset BadgeAsset?              @relation(fields: [badgeAssetId], references: [id], onDelete: SetNull)
  stories    ContentSpotlightStory[]

  @@index([status, startAt, endAt])
  @@index([priority])
  @@map("content_spotlights")
}

model ContentSpotlightStory {
  id                String   @id @default(cuid())
  spotlightId       String   @map("spotlight_id")
  storyId           BigInt   @map("story_id")
  sortOrder         Int      @map("sort_order")
  isFeatured        Boolean  @default(false) @map("is_featured")
  cardTitleOverride String?  @map("card_title_override")

  spotlight ContentSpotlight @relation(fields: [spotlightId], references: [id], onDelete: Cascade)
  story     Story            @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([spotlightId, storyId])
  @@index([spotlightId, sortOrder])
  @@map("content_spotlight_stories")
}

model ContentCalendarSetting {
  id        String   @id @default("global")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("content_calendar_settings")
}

model StoryStudioPreset {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  defaults    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  drafts StoryStudioDraft[]

  @@map("story_studio_presets")
}

/** Singleton row (`id = global`) for Story Studio admin options (e.g. art style prompt overrides). */
model StoryStudioSettings {
  id                          String @id @default("global")
  artStylePromptOverridesJson Json   @default("{}") @map("art_style_prompt_overrides_json")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("story_studio_settings")
}

model StoryStudioDraft {
  id              String   @id @default(cuid())
  createdByUserId String?  @map("created_by_user_id")
  title           String   @default("Untitled draft")
  slug            String
  mode            String   @default("quick")
  presetId        String?  @map("preset_id")
  request         Json     @default("{}")
  brief           Json?
  scriptPackage   Json?    @map("script_package")
  linkedStoryId   BigInt?  @map("linked_story_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy   User?                    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  preset      StoryStudioPreset?       @relation(fields: [presetId], references: [id], onDelete: SetNull)
  linkedStory Story?                   @relation(fields: [linkedStoryId], references: [id], onDelete: SetNull)
  episodes    StoryStudioDraftEpisode[]
  assets      StoryStudioGeneratedAsset[]
  jobs        StoryStudioGenerationJob[]

  @@index([createdByUserId])
  @@index([updatedAt])
  @@map("story_studio_drafts")
}

model StoryStudioDraftEpisode {
  id                       String   @id @default(cuid())
  draftId                  String   @map("draft_id")
  sortOrder                Int      @map("sort_order")
  title                    String   @default("Episode")
  scriptText               String   @default("") @map("script_text")
  summary                  String?
  estimatedDurationSeconds Int?     @map("estimated_duration_seconds")
  notes                    Json?

  draft  StoryStudioDraft          @relation(fields: [draftId], references: [id], onDelete: Cascade)
  assets StoryStudioGeneratedAsset[]

  @@index([draftId])
  @@map("story_studio_draft_episodes")
}

model StoryStudioGeneratedAsset {
  id               String   @id @default(cuid())
  draftId          String   @map("draft_id")
  draftEpisodeId   String?  @map("draft_episode_id")
  kind             String
  storageKey       String?  @map("storage_key")
  publicUrl        String?  @map("public_url")
  mimeType         String?  @map("mime_type")
  vendor           String   @default("")
  vendorArtifactId String?  @map("vendor_artifact_id")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  draft        StoryStudioDraft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftEpisode StoryStudioDraftEpisode? @relation(fields: [draftEpisodeId], references: [id], onDelete: SetNull)

  @@index([draftId])
  @@map("story_studio_generated_assets")
}

model StoryStudioGenerationJob {
  id           String    @id @default(cuid())
  draftId      String    @map("draft_id")
  step         String
  status       String    @default("queued")
  errorMessage String?   @map("error_message")
  attempts     Int       @default(0)
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  payload      Json?
  resultRef    String?   @map("result_ref")

  draft StoryStudioDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([status])
  @@map("story_studio_generation_jobs")
}

model Episode {
  id             BigInt   @id @default(autoincrement())
  storyId        BigInt   @map("story_id")
  episodeNumber  Int      @map("episode_number")
  slug           String?
  label          String?
  title          String
  duration       String?
  durationSeconds Int?    @map("duration_seconds")
  audioUrl          String?  @map("audio_url")
  /** R2 object key in the private audio bucket (no leading slash), e.g. audio/slug/episode-1.mp3 */
  audioStorageKey   String?  @map("audio_storage_key")
  description       String?
  isPublished       Boolean  @default(false) @map("is_published")
  isPremium         Boolean  @default(false) @map("is_premium")
  /** When true, episode is playable without a subscription (sample), even if the series is premium. */
  isFreePreview     Boolean  @default(false) @map("is_free_preview")
  /// JSON array of { id: string | number; text: string } for scrolling transcript (Story Studio / admin).
  transcriptLines   Json?    @map("transcript_lines")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, episodeNumber])
  @@unique([storyId, slug])
  @@map("episodes")
}

model Upload {
  id          BigInt   @id @default(autoincrement())
  fileName    String   @map("file_name")
  fileType    String   @map("file_type")
  fileUrl     String   @map("file_url")
  storagePath String   @map("storage_path")
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("uploads")
}

model StorySeriesLike {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storySlug])
  @@index([storySlug])
  @@map("story_series_likes")
}

model UserSavedStory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storySlug])
  @@index([storySlug])
  @@map("user_saved_stories")
}

model StorySeriesComment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  body      String
  commentRating Int? @map("comment_rating")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storySlug, createdAt])
  @@map("story_series_comments")
}

model StorySeriesRating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storySlug])
  @@index([storySlug])
  @@map("story_series_ratings")
}

model Campaign {
  id              String         @id @default(cuid())
  type            CampaignType
  status          CampaignStatus @default(draft)
  internalName    String         @map("internal_name")
  priority        Int            @default(0)
  pinnedHighest   Boolean        @default(false) @map("pinned_highest")
  startsAt        DateTime       @map("starts_at")
  endsAt          DateTime       @map("ends_at")
  timezone        String         @default("UTC")
  publishedAt     DateTime?      @map("published_at")
  archivedAt      DateTime?      @map("archived_at")
  createdByUserId String?        @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  createdBy          User?                    @relation("CampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  placements         CampaignPlacement[]
  notificationDetail NotificationBarDetail?
  trialDetail        TrialOfferDetail?
  promoDetail        PromoCodeDetail?
  analyticsEvents    CampaignAnalyticsEvent[]
  statusHistory      CampaignStatusHistory[]
  promoRedemptions   PromoCodeRedemption[]
  trialClaims        TrialClaim[]
  trialsLinkingPromo TrialOfferDetail[]       @relation("TrialLinkedPromo")

  @@index([status, startsAt, endsAt, type])
  @@index([priority, publishedAt])
  @@index([type, status])
  @@map("campaigns")
}

model CampaignPlacement {
  campaignId String               @map("campaign_id")
  placement  CampaignPlacementKey
  campaign   Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, placement])
  @@index([placement])
  @@map("campaign_placements")
}

model NotificationBarDetail {
  campaignId       String                    @id @map("campaign_id")
  messagePrimary   String                    @map("message_primary")
  messageSecondary String?                   @map("message_secondary")
  ctaLabel         String?                   @map("cta_label")
  ctaUrl           String?                   @map("cta_url")
  dismissible      Boolean                   @default(true)
  dismissPolicy    NotificationDismissPolicy @default(session) @map("dismiss_policy")
  iconOrBadgeText  String?                   @map("icon_or_badge_text")
  bgVariant        String                    @default("brand") @map("bg_variant")
  textVariant      String                    @default("light") @map("text_variant")
  /// Custom top bar background (#RRGGBB). When set, overrides bgVariant for the public bar.
  barBackgroundHex String?                   @map("bar_background_hex")
  audience         CampaignAudience          @default(all)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("notification_bar_campaign_details")
}

model TrialOfferDetail {
  campaignId             String         @id @map("campaign_id")
  headline               String
  subheadline            String?        @map("subheadline")
  badgeText              String?        @map("badge_text")
  ctaLabel               String         @default("Start trial") @map("cta_label")
  offerKind              TrialOfferKind @default(fixed_duration) @map("offer_kind")
  durationDays           Int            @default(7) @map("duration_days")
  eligibilityJson        Json           @default("{}") @map("eligibility_json")
  maxTotalRedemptions    Int?           @map("max_total_redemptions")
  maxPerUser             Int?           @map("max_per_user")
  unlimitedRedemptions   Boolean        @default(true) @map("unlimited_redemptions")
  autoApplySignup        Boolean        @default(false) @map("auto_apply_signup")
  linkedPromoCampaignId  String?        @map("linked_promo_campaign_id")
  landingSlug            String?        @map("landing_slug")
  /// Custom top bar background (#RRGGBB). When null, trial bar uses default emerald styling.
  barBackgroundHex       String?        @map("bar_background_hex")

  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  linkedPromo Campaign? @relation("TrialLinkedPromo", fields: [linkedPromoCampaignId], references: [id], onDelete: SetNull)

  @@map("trial_offer_campaign_details")
}

model PromoCodeDetail {
  campaignId         String            @id @map("campaign_id")
  codeRaw            String            @map("code_raw")
  codeNormalized     String            @unique @map("code_normalized")
  publicTitle        String            @map("public_title")
  description        String            @default("")
  discountType       DiscountType      @map("discount_type")
  discountValue      Int               @map("discount_value")
  appliesToAllPlans  Boolean           @default(true) @map("applies_to_all_plans")
  planKeysJson       Json              @default("[]") @map("plan_keys_json")
  durationMode       PromoDurationMode @default(once) @map("duration_mode")
  recurringCycles    Int?              @map("recurring_cycles")
  stackingRule       PromoStackingRule @default(none) @map("stacking_rule")
  firstPurchaseOnly  Boolean           @default(false) @map("first_purchase_only")
  loggedInOnly       Boolean           @default(false) @map("logged_in_only")
  newUsersOnly       Boolean           @default(false) @map("new_users_only")
  newUserMaxAgeDays  Int?              @map("new_user_max_age_days")
  onePerAccount      Boolean           @default(true) @map("one_per_account")
  maxUsesTotal       Int?              @map("max_uses_total")
  maxUsesPerUser     Int?              @map("max_uses_per_user")
  unlimitedUses      Boolean           @default(true) @map("unlimited_uses")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([codeNormalized])
  @@map("promo_code_campaign_details")
}

model CampaignSettings {
  id                       String                    @id @default("default")
  defaultTimezone          String                    @default("America/New_York") @map("default_timezone")
  defaultCampaignPriority  Int                       @default(0) @map("default_campaign_priority")
  allowMultipleTopBars     Boolean                   @default(false) @map("allow_multiple_top_bars")
  globalKillSwitch         Boolean                   @default(false) @map("global_kill_switch")
  testModeEnabled          Boolean                   @default(false) @map("test_mode_enabled")
  testModeUserIdsJson      Json                      @default("[]") @map("test_mode_user_ids_json")
  previewHeaderName        String                    @default("x-campaign-preview") @map("preview_header_name")
  previewHeaderSecret      String?                   @map("preview_header_secret")
  defaultBarDismissPolicy  NotificationDismissPolicy @default(session) @map("default_bar_dismiss_policy")
  promosCanStackWithTrials Boolean                   @default(false) @map("promos_can_stack_with_trials")

  @@map("campaign_settings")
}

model CampaignAnalyticsEvent {
  id         String               @id @default(cuid())
  campaignId String               @map("campaign_id")
  type       AnalyticsEventType
  placement  CampaignPlacementKey? @map("placement")
  userId     String?              @map("user_id")
  sessionKey String?              @map("session_key")
  metadata   Json                 @default("{}")
  createdAt  DateTime             @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([type, createdAt])
  @@map("campaign_analytics_events")
}

model PromoCodeRedemption {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  userId     String   @map("user_id")
  context    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId, userId])
  @@index([userId, createdAt])
  @@map("promo_code_redemptions")
}

model TrialClaim {
  id         String    @id @default(cuid())
  campaignId String    @map("campaign_id")
  userId     String    @map("user_id")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
  @@map("trial_claims")
}

model CampaignStatusHistory {
  id          String          @id @default(cuid())
  campaignId  String          @map("campaign_id")
  fromStatus  CampaignStatus? @map("from_status")
  toStatus    CampaignStatus  @map("to_status")
  actorUserId String?         @map("actor_user_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User?    @relation("CampaignStatusActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@map("campaign_status_history")
}
