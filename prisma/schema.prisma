generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  active
  suspended
  banned
  pending
  deleted
}

enum RiskLevel {
  none
  low
  medium
  high
}

enum CreditLedgerType {
  grant
  spend
  refund
  promo
  manual_adjustment
}

enum NoteVisibility {
  internal
  support
}

enum AdminInboxEventType {
  user_signup
  subscription_active
}

// NextAuth models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  storySeriesLikes    StorySeriesLike[]
  userSavedStories    UserSavedStory[]
  storySeriesComments StorySeriesComment[]
  storySeriesRatings  StorySeriesRating[]
  storyStudioDrafts   StoryStudioDraft[]
  customerCreditLedger   CustomerCreditLedger[]
  customerAdminNotes     CustomerAdminNote[]
  customerAuditLogs      CustomerAuditLog[]
  customerPurchases      CustomerPurchase[]
  creditLedgerCreatedBy  CustomerCreditLedger[] @relation("CreditLedgerCreatedBy")
  adminNotesAuthored     CustomerAdminNote[]    @relation("AdminNoteAuthor")
  auditLogsAsActor       CustomerAuditLog[]     @relation("AuditLogActor")
  inboxEventsAsSubject   AdminInboxEvent[]      @relation("InboxEventSubject")
  adminNotificationSeen  AdminNotificationSeen?
}

model AdminInboxEvent {
  id        String             @id @default(cuid())
  type      AdminInboxEventType
  userId    String             @map("user_id")
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now()) @map("created_at")

  user User @relation("InboxEventSubject", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@map("admin_inbox_events")
}

model AdminNotificationSeen {
  adminUserId String   @id @map("admin_user_id")
  lastSeenAt  DateTime @map("last_seen_at")

  admin User @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_notification_seen")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  fullName           String?  @map("full_name")
  avatarUrl          String?  @map("avatar_url")
  role               String   @default("user")
  subscriptionStatus String   @default("free") @map("subscription_status")
  stripeCustomerId   String?  @map("stripe_customer_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  /// Platform account state (distinct from Stripe subscriptionStatus)
  accountStatus AccountStatus @default(active) @map("account_status")
  /// Display tier: free, plus, family, etc.
  subscriptionPlan String? @map("subscription_plan")
  creditBalance    Int     @default(0) @map("credit_balance")
  lastActiveAt     DateTime? @map("last_active_at")
  loginCount       Int       @default(0) @map("login_count")
  lifetimeSpendCents Int     @default(0) @map("lifetime_spend_cents")
  refundCount      Int       @default(0) @map("refund_count")
  /// Denormalized: likes + saves + comments + ratings + studio drafts (refreshed on demand / detail view)
  totalEngagementCount Int   @default(0) @map("total_engagement_count")
  isFlagged        Boolean   @default(false) @map("is_flagged")
  isVip            Boolean   @default(false) @map("is_vip")
  riskLevel        RiskLevel @default(none) @map("risk_level")
  internalTags     Json      @default("[]") @map("internal_tags")
  marketingOptIn   Boolean   @default(false) @map("marketing_opt_in")
  isGuardianManaged Boolean  @default(false) @map("is_guardian_managed")
  isMinorAccount   Boolean   @default(false) @map("is_minor_account")
  consentStatus    String?   @map("consent_status")
  communicationRestricted Boolean @default(false) @map("communication_restricted")
  complianceNotes  String?   @map("compliance_notes")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountStatus])
  @@index([subscriptionStatus])
  @@index([lastActiveAt])
  @@index([createdAt])
  @@map("profiles")
}

model CustomerCreditLedger {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  type             CreditLedgerType
  amount           Int
  balanceAfter     Int              @map("balance_after")
  reason           String           @default("")
  source           String           @default("")
  createdByAdminId String?          @map("created_by_admin_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByAdmin User? @relation("CreditLedgerCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("customer_credit_ledger")
}

model CustomerAdminNote {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  authorAdminId  String         @map("author_admin_id")
  body           String
  visibility     NoteVisibility @default(internal)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorAdmin User @relation("AdminNoteAuthor", fields: [authorAdminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("customer_admin_notes")
}

model CustomerAuditLog {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  actorAdminId String   @map("actor_admin_id")
  actionType   String   @map("action_type")
  reason       String   @default("")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actorAdmin User @relation("AuditLogActor", fields: [actorAdminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actorAdminId])
  @@map("customer_audit_logs")
}

model CustomerPurchase {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  amountCents  Int      @map("amount_cents")
  currency     String   @default("usd")
  status       String   @default("paid")
  productType  String   @default("subscription") @map("product_type")
  provider     String   @default("stripe")
  providerRef  String?  @map("provider_ref")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("customer_purchases")
}

model Story {
  id            BigInt   @id @default(autoincrement())
  slug          String   @unique
  seriesTitle   String   @map("series_title")
  title         String
  subtitle      String?
  ageGroup      String?  @map("age_group")
  ageRange      String?  @map("age_range")
  durationLabel String?  @map("duration_label")
  durationMinutes Int?   @map("duration_minutes")
  durationBucket String? @map("duration_bucket")
  summary       String?
  fullDescription String? @map("full_description")
  coverUrl      String?  @map("cover_url")
  accent        String?
  genre         String?
  mood          String?
  isSeries      Boolean  @default(false) @map("is_series")
  seriesTagline String?  @map("series_tagline")
  universe      String?
  readingLevel  String?  @map("reading_level")
  topics        Json?
  characterTags Json?    @map("character_tags")
  cardTitleOverride String? @map("card_title_override")
  cardDescriptionOverride String? @map("card_description_override")
  badgeLabelOverride String? @map("badge_label_override")
  popularityScore Int      @default(10) @map("popularity_score")
  sortPriority  Int      @default(0) @map("sort_priority")
  publishedAt   DateTime? @map("published_at")
  isFeatured    Boolean  @default(false) @map("is_featured")
  isPublished   Boolean  @default(false) @map("is_published")
  isPremium     Boolean  @default(false) @map("is_premium")
  metaTitle     String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  episodes Episode[]
  studioDrafts StoryStudioDraft[]

  @@map("stories")
}

model StoryStudioPreset {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  defaults    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  drafts StoryStudioDraft[]

  @@map("story_studio_presets")
}

model StoryStudioDraft {
  id              String   @id @default(cuid())
  createdByUserId String?  @map("created_by_user_id")
  title           String   @default("Untitled draft")
  slug            String
  mode            String   @default("quick")
  presetId        String?  @map("preset_id")
  request         Json     @default("{}")
  brief           Json?
  scriptPackage   Json?    @map("script_package")
  linkedStoryId   BigInt?  @map("linked_story_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy   User?                    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  preset      StoryStudioPreset?       @relation(fields: [presetId], references: [id], onDelete: SetNull)
  linkedStory Story?                   @relation(fields: [linkedStoryId], references: [id], onDelete: SetNull)
  episodes    StoryStudioDraftEpisode[]
  assets      StoryStudioGeneratedAsset[]
  jobs        StoryStudioGenerationJob[]

  @@index([createdByUserId])
  @@index([updatedAt])
  @@map("story_studio_drafts")
}

model StoryStudioDraftEpisode {
  id                       String   @id @default(cuid())
  draftId                  String   @map("draft_id")
  sortOrder                Int      @map("sort_order")
  title                    String   @default("Episode")
  scriptText               String   @default("") @map("script_text")
  summary                  String?
  estimatedDurationSeconds Int?     @map("estimated_duration_seconds")
  notes                    Json?

  draft  StoryStudioDraft          @relation(fields: [draftId], references: [id], onDelete: Cascade)
  assets StoryStudioGeneratedAsset[]

  @@index([draftId])
  @@map("story_studio_draft_episodes")
}

model StoryStudioGeneratedAsset {
  id               String   @id @default(cuid())
  draftId          String   @map("draft_id")
  draftEpisodeId   String?  @map("draft_episode_id")
  kind             String
  storageKey       String?  @map("storage_key")
  publicUrl        String?  @map("public_url")
  mimeType         String?  @map("mime_type")
  vendor           String   @default("")
  vendorArtifactId String?  @map("vendor_artifact_id")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  draft        StoryStudioDraft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftEpisode StoryStudioDraftEpisode? @relation(fields: [draftEpisodeId], references: [id], onDelete: SetNull)

  @@index([draftId])
  @@map("story_studio_generated_assets")
}

model StoryStudioGenerationJob {
  id           String    @id @default(cuid())
  draftId      String    @map("draft_id")
  step         String
  status       String    @default("queued")
  errorMessage String?   @map("error_message")
  attempts     Int       @default(0)
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  payload      Json?
  resultRef    String?   @map("result_ref")

  draft StoryStudioDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([status])
  @@map("story_studio_generation_jobs")
}

model Episode {
  id             BigInt   @id @default(autoincrement())
  storyId        BigInt   @map("story_id")
  episodeNumber  Int      @map("episode_number")
  slug           String?
  label          String?
  title          String
  duration       String?
  durationSeconds Int?    @map("duration_seconds")
  audioUrl          String?  @map("audio_url")
  /** R2 object key in the private audio bucket (no leading slash), e.g. audio/slug/episode-1.mp3 */
  audioStorageKey   String?  @map("audio_storage_key")
  description       String?
  isPublished       Boolean  @default(false) @map("is_published")
  isPremium         Boolean  @default(false) @map("is_premium")
  /** When true, episode is playable without a subscription (sample), even if the series is premium. */
  isFreePreview     Boolean  @default(false) @map("is_free_preview")
  /// JSON array of { id: string | number; text: string } for scrolling transcript (Story Studio / admin).
  transcriptLines   Json?    @map("transcript_lines")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, episodeNumber])
  @@unique([storyId, slug])
  @@map("episodes")
}

model Upload {
  id          BigInt   @id @default(autoincrement())
  fileName    String   @map("file_name")
  fileType    String   @map("file_type")
  fileUrl     String   @map("file_url")
  storagePath String   @map("storage_path")
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("uploads")
}

model StorySeriesLike {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storySlug])
  @@index([storySlug])
  @@map("story_series_likes")
}

model UserSavedStory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storySlug])
  @@index([storySlug])
  @@map("user_saved_stories")
}

model StorySeriesComment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  body      String
  commentRating Int? @map("comment_rating")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storySlug, createdAt])
  @@map("story_series_comments")
}

model StorySeriesRating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storySlug String   @map("story_slug")
  rating    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storySlug])
  @@index([storySlug])
  @@map("story_series_ratings")
}
