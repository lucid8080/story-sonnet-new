{
  "name": "story-app",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "node ./scripts/prisma-env.mjs generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "postinstall": "node ./scripts/prisma-env.mjs generate",
    "db:push": "node ./scripts/prisma-env.mjs db push",
    "db:migrate": "node ./scripts/prisma-env.mjs migrate deploy",
    "db:migrate:resolve:content-calendar-rolled-back": "node ./scripts/prisma-env.mjs migrate resolve --rolled-back 20260413100000_content_calendar_spotlights",
    "db:migrate:resolve:content-calendar-applied": "node ./scripts/prisma-env.mjs migrate resolve --applied 20260413100000_content_calendar_spotlights",
    "db:migrate:dev": "node ./scripts/prisma-env.mjs migrate dev",
    "db:studio": "node ./scripts/prisma-env.mjs studio",
    "create-admin": "node --env-file=.env scripts/create-admin.mjs",
    "db:seed": "node --env-file=.env prisma/seed.mjs",
    "backfill:episode-transcripts": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/backfill-episode-transcripts-from-studio.ts"
  },
  "prisma": {
    "seed": "node --env-file=.env prisma/seed.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "3.693.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@prisma/client": "^6.5.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/sanitize-html": "^2.16.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "livekit-client": "^2.18.1",
    "livekit-server-sdk": "^2.15.1",
    "lucide-react": "^0.477.0",
    "music-metadata": "^11.12.3",
    "next": "^15.2.4",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.3",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
